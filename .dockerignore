# ==========================
# Environment Files - Keep examples, ignore sensitive
# ==========================
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.staging
**/.env.test

# But keep example files for documentation
!.env.example
!.env.docker.example
!backend/.env.example
!frontend/.env.example

# ==========================
# Dependencies
# ==========================
**/node_modules/
**/npm-debug.log*
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml

# ==========================
# Build outputs
# ==========================
**/dist/
**/build/
**/out/
**/.next/
**/.cache/
**/.vite/

# ==========================
# Version Control
# ==========================
**/.git
**/.gitignore
**/.gitattributes
**/.github/

# ==========================
# Docker
# ==========================
**/Dockerfile
**/docker-compose*.yml
**/docker-compose*.yaml
**/.dockerignore
README-docker.md

# ==========================
# Tests
# ==========================
**/coverage/
**/.nyc_output/
**/jest.config.js
**/vitest.config.ts
**/test-results/

# ==========================
# Logs
# ==========================
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ==========================
# OS files
# ==========================
**/.DS_Store
**/Thumbs.db
**/desktop.ini

# ==========================
# IDE
# ==========================
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*~

# ==========================
# Documentation (can be large)
# ==========================
**/README.md
**/docs/
**/*.md
!README.md  # Keep root README

# ==========================
# Temporary files
# ==========================
**/*.tmp
**/*.temp
**/.temp
**/.tmp

# ==========================
# Backend specific
# ==========================
backend/sequelize-meta.json

# ==========================
# Frontend specific
# ==========================
frontend/.vite/
frontend/.vitepress/cache/

# ==========================
# Database (don't copy local DB)
# ==========================
data/
*.db
*.sqlite
*.sqlite3

# ==========================
# Misc archives
# ==========================
*.tgz
*.tar.gz
*.zip
*.rar