{
  "name": "company-incorporation-backend",
  "version": "1.0.0",
  "description": "Backend for Company Incorporation Tool",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo",
    "seed:undo:all": "npx sequelize-cli db:seed:undo:all",
    "db:reset": "npm run migrate:undo:all && npm run migrate && npm run seed",
   "migrate:docker": "npx sequelize-cli db:migrate --env docker",
   "seed:docker": "npx sequelize-cli db:seed:all --env docker",
   "db:reset:docker": "npm run migrate:undo:all -- --env docker && npm run migrate:docker && npm run seed:docker"
  },
  "keywords": [],
  "author": "Rajan Kumar Gupta",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "pg": "^8.19.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.2"
  }
}
