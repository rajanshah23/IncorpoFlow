# ==========================
# Environment Files
# ==========================
# Ignore actual environment files (not examples)
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.staging
**/.env.test

# But KEEP example environment files
!.env.example
!.env.docker.example
!backend/.env.example
!frontend/.env.example
!**/.env.example

# ==========================
# Node.js / NPM
# ==========================
**/node_modules/
**/npm-debug.log*
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml

# ==========================
# Build / Dist folders
# ==========================
**/dist/
**/build/
**/out/
**/.next/
**/.cache/

# ==========================
# Backend
# ==========================
backend/coverage/
backend/.nyc_output/
backend/sequelize-meta.json
backend/logs/
backend/*.log

# ==========================
# Frontend
# ==========================
frontend/.vite/
frontend/.vitepress/cache/

# ==========================
# Database
# ==========================
data/
*.db
*.sqlite
*.sqlite3

# ==========================
# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================
# OS / IDE / Editor files
# ==========================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================
# Docker
# ==========================
docker-compose.override.yml
docker-compose.override.yaml
**/docker.env

# ==========================
# Misc
# ==========================
*.tgz
*.tar.gz
.DS_Store
.env.keys
*.pem
*.p12
*.pfx